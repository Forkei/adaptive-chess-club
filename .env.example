# Metropolis Chess Club — environment template
# Copy to `.env` and fill in values as needed.

# --- LLM ---
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# --- Database ---
# Local dev default. On HF Spaces this is baked into the Docker image as
# sqlite:////data/metropolis_chess.db (persistent volume). Override here for
# docker-compose local dev.
DATABASE_URL=sqlite:///./metropolis_chess.db

# --- Session (Phase 4.0a) ---
# Arbitrary secret for cookie signing. Leave empty for unsigned cookies (dev only).
SESSION_SECRET=

# --- Logging ---
LOG_DIR=logs
LOG_LEVEL=INFO

# --- Memory generation (Phase 1) ---
MEMORY_GEN_TARGET=40
MEMORY_GEN_MIN=30
MEMORY_GEN_MAX=50

# --- Engines (Phase 2a) ---
# Leave STOCKFISH_PATH blank to auto-discover on PATH.
# In Docker the image sets /usr/games/stockfish.
STOCKFISH_PATH=
# Maia-2 weights cache location. Docker uses /app/maia2_models (pre-baked).
MAIA2_CACHE_DIR=

# --- Redis (Phase 2a) ---
# If blank, mood/cache state falls back to in-process memory (fine for single-worker).
# In Docker compose: redis://redis:6379/0
# On HF Spaces: leave blank (in-process fallback is intentional).
REDIS_URL=

# --- Real-time / Socket.IO (Phase 3b) ---
MATCH_DISCONNECT_COOLDOWN_SECONDS=300
PLAYER_CHAT_MIN_INTERVAL_MS=500
PENDING_CHAT_MAX_MESSAGES=10
PENDING_CHAT_MAX_CHARS=2000
AGENT_THINKING_SOUL_OVERHEAD_SECONDS=1.5

# --- Character API (single-character mode) ---
# Create/edit/clone character endpoints are disabled unless this is set to true.
# Tests flip it to True in their scope.
ALLOW_CHARACTER_API=false

# --- Email / SMTP (Phase 4.0a, optional) ---
# When blank, password-reset tokens are written to LOG_DIR (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@metropolis-chess.local

# --- Tests ---
# RUN_LIVE_LLM_TESTS=1
