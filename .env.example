# Metropolis Chess Club — Phase 1 environment
# Copy this file to `.env` and fill in the values you need.

# Gemini (primary LLM)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Database
DATABASE_URL=sqlite:///./metropolis_chess.db

# Logging
LOG_DIR=logs
LOG_LEVEL=INFO

# Memory generation
# Target count and acceptable range the generator will return per character.
MEMORY_GEN_TARGET=40
MEMORY_GEN_MIN=30
MEMORY_GEN_MAX=50

# Opt-in live LLM tests. Only used by pytest; never read by the app.
# RUN_LIVE_LLM_TESTS=1
