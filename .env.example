# Metropolis Chess Club — environment template
# Copy to `.env` and fill in values as needed.

# --- LLM ---
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# --- Database ---
DATABASE_URL=sqlite:///./metropolis_chess.db

# --- Logging ---
LOG_DIR=logs
LOG_LEVEL=INFO

# --- Memory generation (Phase 1) ---
MEMORY_GEN_TARGET=40
MEMORY_GEN_MIN=30
MEMORY_GEN_MAX=50

# --- Engines (Phase 2a) ---
# Leave STOCKFISH_PATH blank to auto-discover on PATH.
# In Docker the image sets /usr/games/stockfish.
STOCKFISH_PATH=
# Maia-2 weights cache location. Docker uses /app/.cache/maia2.
MAIA2_CACHE_DIR=

# --- Redis (Phase 2a) ---
# If blank, mood/cache state falls back to in-process memory (fine for dev).
# In Docker compose: redis://redis:6379/0
REDIS_URL=

# --- Real-time / Socket.IO (Phase 3b) ---
# How long a player has after closing their tab / losing the socket before the
# match is abandoned (character wins, post-match processor runs). Default 300s.
MATCH_DISCONNECT_COOLDOWN_SECONDS=300
# Floor on `player_chat` event spacing per socket. Excess chat is rejected with
# `player_chat_rate_limited`, not a disconnect.
PLAYER_CHAT_MIN_INTERVAL_MS=500
# Caps on the pending-chat FIFO merged into the next Subconscious call.
PENDING_CHAT_MAX_MESSAGES=10
PENDING_CHAT_MAX_CHARS=2000
# UI-latency budget added to the engine time budget when emitting
# `agent_thinking.eta_seconds`. Soft estimate; UI shouldn't treat as hard countdown.
AGENT_THINKING_SOUL_OVERHEAD_SECONDS=1.5

# --- Tests ---
# RUN_LIVE_LLM_TESTS=1
